generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

model TelegramUser {
  id                 Int                  @id @default(autoincrement())
  firstName          String               @map("first_name") @db.VarChar(255)
  lastName           String               @map("last_name") @db.VarChar(255)
  username           String?              @db.VarChar(255)
  avatar             String?              @db.VarChar(500)
  telegramId         BigInt               @unique @map("telegram_id")
  role               UserRole             @default(USER)
  language           String?              @default("en")
  privateChatId      BigInt?              @map("private_chat_id")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  followedCategories UserCategoryFollow[]

  @@map("telegram_users")
}

model Bot {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  token       String   @unique
  active      Boolean  @default(false)
  interactive Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  telegramGroupConfigs TelegramGroupConfig[]

  @@map("bots")
}

model TelegramGroupConfig {
  id          Int      @id @default(autoincrement())
  botId       Int      @map("bot_id")
  chatId      String   @map("chat_id") @db.VarChar(255) // ID of the group chat
  topicId     Int?     @map("topic_id")                 // ID of the topic (if applicable)
  groupName   String?  @map("group_name") @db.VarChar(500)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  bot         Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, chatId, topicId])
  @@map("telegram_group_configs")
}

model AppCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(500)
  icon        String?  @db.VarChar(50)
  color       String?  @db.VarChar(30)
  sortOrder   Int      @default(0) @map("sort_order")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  followers UserCategoryFollow[]

  @@map("app_categories")
}

model UserCategoryFollow {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  categoryId Int      @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     TelegramUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  category AppCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@map("user_category_follows")
}

// ─── AppStoreSpy Integration ──────────────────────────

enum Store {
  PLAY
  IOS
}

enum CrawlStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum TriggerType {
  NT1
  NT2
  NT3
}

model TrackedApp {
  id          Int       @id @default(autoincrement())
  appId       String    @map("app_id") @db.VarChar(255)
  store       Store     @default(PLAY)
  name        String    @db.VarChar(500)
  category    String?   @db.VarChar(100)
  icon        String?   @db.VarChar(1000)
  releaseDate DateTime? @map("release_date") @db.Date
  releaseNotifiedAt DateTime? @map("release_notified_at")
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  dailyData      AppDailyData[]
  triggerAlerts  AppTriggerAlert[]

  @@unique([appId, store])
  @@map("tracked_apps")
}

model AppDailyData {
  id           Int       @id @default(autoincrement())
  trackedAppId Int       @map("tracked_app_id")
  date         DateTime  @db.Date
  downloads    Int       @default(0)
  revenue      Int       @default(0)
  ratingCount  Int?      @map("rating_count")
  ratingValue  Float?    @map("rating_value")
  version      String?   @db.VarChar(50)
  updatedDate  DateTime? @map("updated_date") @db.Date
  rawResponse  Json?     @map("raw_response")
  createdAt    DateTime  @default(now()) @map("created_at")

  trackedApp TrackedApp @relation(fields: [trackedAppId], references: [id], onDelete: Cascade)

  @@unique([trackedAppId, date])
  @@map("app_daily_data")
}

model AppTriggerAlert {
  id           Int         @id @default(autoincrement())
  trackedAppId Int         @map("tracked_app_id")
  triggerDate  DateTime    @map("trigger_date") @db.Date
  triggerType  TriggerType @map("trigger_type")
  d0Downloads  Int         @map("d0_downloads")
  d1Downloads  Int         @map("d1_downloads")
  d2Downloads  Int         @map("d2_downloads")
  growthRate   Float       @map("growth_rate")
  notes        String?     @db.Text
  createdAt    DateTime    @default(now()) @map("created_at")

  trackedApp TrackedApp @relation(fields: [trackedAppId], references: [id], onDelete: Cascade)

  @@map("app_trigger_alerts")
}

model CrawlLog {
  id            Int         @id @default(autoincrement())
  startedAt     DateTime    @default(now()) @map("started_at")
  finishedAt    DateTime?   @map("finished_at")
  status        CrawlStatus @default(RUNNING)
  totalApps     Int         @default(0) @map("total_apps")
  processedApps Int         @default(0) @map("processed_apps")
  errors        String?     @db.Text
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("crawl_logs")
}
