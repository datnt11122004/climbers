# Environment Variables
PORT=3000
NODE_ENV=development

# Google OAuth2 Credentials file path (relative to project root)
GOOGLE_CREDENTIALS_PATH=data/key.json

# Google Refresh Token (obtained after OAuth consent flow)
# Leave empty initially, then add after completing OAuth flow via /admob/auth/url
GOOGLE_REFRESH_TOKEN=

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# App Lock Configuration (10 minutes = 600 seconds)
APP_LOCK_TTL_SECONDS=600